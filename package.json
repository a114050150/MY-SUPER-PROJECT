{
  "name": "world-charity-day",
  "version": "1.0.0",
  "description": "Static site for World Charity Day - demo and mock donate endpoint",
  "main": "index.html",
  "scripts": {
    "start:static": "npx http-server -c-1 . -p 8000",
    "start:mock": "node mock-server.js",
    "start:all": "concurrently \"npm run start:mock\" \"npm run start:static\"",
    "deploy:ghpages": "npx gh-pages -d ."
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}
